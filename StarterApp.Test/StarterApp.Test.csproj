<Project Sdk="Microsoft.NET.Sdk">

  <!-- this file was generated when running: dotnet new xunit -->
  <!-- it is the project config file - same idea as package.json in JavaScript -->
  <!-- it tells .NET what packages the test project needs -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- collects test coverage numbers -->
    <PackageReference Include="coverlet.collector" Version="6.0.4" />
    <!-- the fake in-memory database so tests dont need real PostgreSQL -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.0" />
    <!-- needed to run tests -->
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <!-- for creating fake/mock objects in tests -->
    <PackageReference Include="Moq" Version="4.20.72" />
    <!-- the xUnit testing framework -->
    <PackageReference Include="xunit" Version="2.9.3" />
    <!-- lets you see and run tests inside VS Code -->
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <ItemGroup>
    <!-- reference to the database project so tests can use repositories and models -->
    <ProjectReference Include="..\StarterApp.Database\StarterApp.Database.csproj" />
  </ItemGroup>

</Project>
