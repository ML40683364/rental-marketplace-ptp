<?xml version="1.0" encoding="utf-8" ?>
<!-- ItemsListPage: scrollable list of all rental items — tap one to open its detail page -->
<!-- data and commands live in ItemsListViewModel -->
<ContentPage x:Class="StarterApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="{Binding Title}">

    <!-- toolbar button in the top-right corner — triggers CreateItemCommand to open CreateItemPage -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="+ List Item"
                     Command="{Binding CreateItemCommand}"/>
    </ContentPage.ToolbarItems>

    <!-- i had to use a Grid here so the search bar and filters sit above the scrollable list
         they were inside RefreshView before and that was blocking keyboard input - RefreshView
         intercepts touch events which stopped the SearchBar and Picker from working
         i also added a row at the bottom for the Next/Previous pagination buttons -->
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="15" RowSpacing="8">

        <!-- i switched from SearchBar to Entry because SearchBar was unreliable on Windows MAUI
             Entry is simpler and the text binding works properly -->
        <!-- search row: text box on the left, Search button on the right -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
                   Placeholder="Search items..."
                   Text="{Binding SearchText}"
                   ReturnCommand="{Binding LoadItemsCommand}"/>
            <Button Grid.Column="1"
                    Text="Search"
                    Command="{Binding LoadItemsCommand}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    Padding="12,0"/>
        </Grid>

        <!-- category filter row - picker on the left, clear button on the right
             user picks a category then taps Search above to apply it
             Clear resets both filters at once -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Picker Grid.Column="0"
                    Title="All Categories"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedCategory}"/>
            <Button Grid.Column="1"
                    Text="Clear"
                    Command="{Binding ClearFiltersCommand}"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#444}"
                    TextColor="{AppThemeBinding Light=#333, Dark=#eee}"
                    CornerRadius="8"
                    Padding="12,0"/>
        </Grid>

        <!-- error banner: only visible when HasError is true in the ViewModel -->
        <Border Grid.Row="2"
                BackgroundColor="#FFEBEE"
                Stroke="#F44336"
                StrokeThickness="1"
                Padding="15"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                    TextColor="#D32F2F"
                    FontSize="14"/>
        </Border>

        <!-- RefreshView now only wraps the list - pull-to-refresh still works -->
        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsBusy, Mode=OneWay}"
                     Command="{Binding LoadItemsCommand}">

            <!-- CollectionView: efficiently renders a scrollable list of items -->
            <!-- EmptyView is shown when the Items list is empty -->
            <CollectionView ItemsSource="{Binding Items}"
                            EmptyView="No items available. Pull to refresh.">
                <CollectionView.ItemTemplate>
                    <!-- DataTemplate defines how each item in the list looks -->
                    <DataTemplate>
                        <Border Margin="0,5"
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <!-- TapGestureRecognizer: makes the whole card tappable -->
                            <!-- AncestorType reaches up to the ViewModel since we're inside a DataTemplate -->
                            <!-- CommandParameter="{Binding .}" passes the current item as the argument -->
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ItemsListViewModel}}, Path=SelectItemCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <!-- left column: title, location, short description -->
                                <StackLayout Grid.Column="0"
                                        Spacing="4">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding Location}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                                    <!-- TailTruncation adds "..." if text is too long -->
                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#888, Dark=#999}"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"/>
                                </StackLayout>
                                <!-- right column: price per day -->
                                <StackLayout Grid.Column="1"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End">
                                    <Label Text="{Binding DailyRate, StringFormat='£{0:F2}'}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}"/>
                                    <Label Text="/day"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light=#888, Dark=#999}"
                                           HorizontalOptions="Center"/>
                                </StackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </RefreshView>

        <!-- pagination bar - Previous on the left, page info in the middle, Next on the right
             the buttons disable themselves when there is no previous/next page using IsEnabled binding -->
        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
            <Button Grid.Column="0"
                    Text="&#8592; Previous"
                    Command="{Binding PreviousPageCommand}"
                    IsEnabled="{Binding HasPreviousPage}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    Padding="16,10"/>
            <Label Grid.Column="1"
                   Text="{Binding PageInfo}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
            <Button Grid.Column="2"
                    Text="Next &#8594;"
                    Command="{Binding NextPageCommand}"
                    IsEnabled="{Binding HasNextPage}"
                    BackgroundColor="#512BD4"
                    TextColor="White"
                    CornerRadius="8"
                    Padding="16,10"/>
        </Grid>

    </Grid>
</ContentPage>
