<?xml version="1.0" encoding="utf-8" ?>
<!-- ReviewsPage: submit a star rating and comment for a completed rental -->
<!-- only reachable from RentalsPage when a rental status is Completed -->
<!-- data and commands live in ReviewsViewModel -->
<ContentPage x:Class="StarterApp.Views.ReviewsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">

            <!-- error banner: only visible when HasError is true in the ViewModel -->
            <Border BackgroundColor="#FFEBEE" Stroke="#F44336" StrokeThickness="1"
                    Padding="15" IsVisible="{Binding HasError}">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}" TextColor="#D32F2F" FontSize="14"/>
            </Border>

            <!-- review submission form -->
            <Border Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <StackLayout Spacing="12">
                    <Label Text="How was your experience?" FontSize="18" FontAttributes="Bold"/>

                    <!-- Slider: user drags to pick 1-5 stars, label updates live to show the value -->
                    <Label Text="Rating" FontSize="14"
                           TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                    <Slider Minimum="1" Maximum="5"
                            Value="{Binding SelectedRating}"/>
                    <!-- StarDisplay shows ★★★☆☆ style — updates live as the slider moves -->
                    <Label Text="{Binding StarDisplay}"
                           HorizontalOptions="Center"
                           FontSize="32"
                           TextColor="#FFD700"
                           FontAttributes="Bold"/>

                    <!-- optional comment box -->
                    <Label Text="Comment (optional)" FontSize="14"
                           TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                    <Border Stroke="{AppThemeBinding Light=#ccc, Dark=#555}" StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#f9f9f9, Dark=#2a2a2a}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Editor Text="{Binding Comment}"
                                Placeholder="Share your experience..."
                                HeightRequest="100"
                                Margin="10,8"/>
                    </Border>

                    <!-- loading indicator shown while submitting -->
                    <ActivityIndicator IsVisible="{Binding IsBusy}"
                                       IsRunning="{Binding IsBusy}"
                                       Color="#512BD4"
                                       HorizontalOptions="Center"/>

                    <!-- triggers ReviewsViewModel.SubmitReviewCommand -->
                    <Button Text="Submit Review"
                            Command="{Binding SubmitReviewCommand}"
                            BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"
                            FontAttributes="Bold"/>

                </StackLayout>
            </Border>

        </StackLayout>
    </ScrollView>
</ContentPage>
