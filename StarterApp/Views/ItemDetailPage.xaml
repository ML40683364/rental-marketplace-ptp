<?xml version="1.0" encoding="utf-8" ?>
<!-- ItemDetailPage: shows full info for one rental item, lets user request a rental, and shows reviews -->
<!-- data and commands live in ItemDetailViewModel -->
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit"
                     Command="{Binding EditItemCommand}"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <StackLayout Padding="15"
                Spacing="15">

            <!-- error banner: only visible when HasError is true in the ViewModel -->
            <Border BackgroundColor="#FFEBEE"
                    Stroke="#F44336"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8"/>
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                        TextColor="#D32F2F"
                        FontSize="14"/>
            </Border>

            <!-- SECTION 1: item info card — title, location, price, description, average rating -->
            <!-- Item.Title means: get the Title property from the Item object inside the ViewModel -->
            <Border Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <StackLayout Spacing="8">
                    <Label Text="{Binding Item.Title}"
                            FontSize="22"
                            FontAttributes="Bold"/>
                    <Label Text="{Binding Item.Location}"
                            FontSize="14"
                           TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                    <!-- StringFormat formats the number: £9.99 per day -->
                    <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}"
                           FontSize="18"
                            FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}"/>
                    <Label Text="{Binding Item.Description}"
                            FontSize="14"
                            Margin="0,8,0,0"/>
                    <Label Text="{Binding AverageRating, StringFormat='★ {0:F1} / 5'}"
                           FontSize="14"
                            Margin="0,4,0,0"/>
                </StackLayout>
            </Border>

            <!-- SECTION 2: rental request form — user picks start and end dates then submits -->
            <Border Padding="20"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <StackLayout Spacing="12">
                    <Label Text="Request Rental"
                            FontSize="18"
                            FontAttributes="Bold"/>
                    <Label Text="Start Date"
                            FontSize="13"
                            TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                    <!-- DatePicker: MinimumDate prevents picking a date in the past -->
                    <DatePicker Date="{Binding StartDate}"
                            MinimumDate="{x:Static sys:DateTime.Today}"/>
                    <Label Text="End Date"
                            FontSize="13"
                            TextColor="{AppThemeBinding Light=#666, Dark=#aaa}"/>
                    <DatePicker Date="{Binding EndDate}"
                            MinimumDate="{x:Static sys:DateTime.Today}"/>
                    <!-- triggers ItemDetailViewModel.RequestRentalCommand -->
                    <Button Text="Request Rental"
                            Command="{Binding RequestRentalCommand}"
                            BackgroundColor="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                </StackLayout>
            </Border>

            <!-- SECTION 3: reviews list — loops through each review and displays it -->
            <!-- EmptyView is shown when the Reviews list has no items -->
            <Label Text="Reviews"
                    FontSize="18"
                    FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding Reviews}"
                    EmptyView="No reviews yet.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5"
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                                Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <StackLayout Spacing="4">
                                <Label Text="{Binding ReviewerName}"
                                        FontAttributes="Bold"
                                        FontSize="14"/>
                                <Label Text="{Binding Rating, StringFormat='★ {0}/5'}"
                                        FontSize="13"/>
                                <Label Text="{Binding Comment}"
                                        FontSize="13"
                                       TextColor="{AppThemeBinding Light=#555, Dark=#bbb}"/>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>
</ContentPage>
